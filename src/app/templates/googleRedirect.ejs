<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Google Login</title>
</head>
<body>
  <div>
    <p>Redirecting to google...</p>
  </div>
</body>
<script>
  const betterAuthUrl = "<%= betterAuthUrl %>";
  const callbackURL = "<%= callbackURL %>";

  console.log("betterAuthUrl:", betterAuthUrl);
  console.log("callbackUrl:", callbackURL);

  (
    async()=>{
      try{
        const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social",{
          method: "POST",
          headers:{
            "Content-type": "application/json"
          },
          credentials: "include",
          body: JSON.stringify({
            provider: "google",
            callbackURL: "<%= callbackURL %>"
          })
        });
        
        const data = await response.json();
        if(data.url){
          window.location.href = data.url
        }else{
          document.body.innerHTML = `<div>
            <p>Error while redirecting.</p>
          </div>`
        }
      }catch(error){
        document.body.innerHTML = `<div>
            <p>Error while redirecting. ${error.message}</p>
          </div>`
      }
    }
  )()
</script>
</html>