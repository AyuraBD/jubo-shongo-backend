model Campaign {
  id           String           @id @default(uuid())
  title        String
  description  String
  longBody     String?          
  category     CampaignCategory
  status       CampaignStatus   @default(DRAFT)

  goalAmount   Float
  raisedAmount Float            @default(0)
  donorCount   Int              @default(0)

  coverImage   String?

  isUrgent     Boolean          @default(false)
  isFeatured   Boolean          @default(false)

  startDate    DateTime?
  endDate      DateTime?

  donations    Donation[]
  
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category])
  @@index([status])
  @@index([isUrgent])
  @@index([isFeatured])
  @@index([deletedAt])
  @@index([endDate])
  @@map("campaigns")
}