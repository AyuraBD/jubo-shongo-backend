model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String?
  type        EventType
  status      EventStatus @default(UPCOMING)
  coverImage  String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  maxAttendees Int?

  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([status])
  @@index([startDate])
  @@map("events")
}